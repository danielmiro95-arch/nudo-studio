# ============================================
# Nudo Studio — Variables de entorno
# ============================================
# Copia este archivo a `.env.local` para desarrollo
# y configura las mismas claves en Vercel.
# ============================================

# --- Email (Resend) ---
RESEND_API_KEY=re_REPLACE_ME
CONTACT_EMAIL_TO=hola@nudostudio.blog
CONTACT_EMAIL_FROM="Nudo Studio <web@nudostudio.blog>"

# --- Asistente IA (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Tienda (Stripe) ---
ENABLE_SHOP=false
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- General ---
NEXT_PUBLIC_SITE_URL=https://nudostudio.blog
NEXT_PUBLIC_SITE_NAME="Nudo Studio"
ASSISTANT_RATE_LIMIT_PER_DAY=20
